# ETF Momentum Backend — environment variable template.
# Copy to `.env` and edit before running.

# Path to the SQLite database file.
# Default: <repo>/data/etf_momentum.db (created on startup)
ETF_DB_PATH=

# Directory containing OHLCV fixture CSVs (one per ETF, code as filename).
# Default: <repo>/backend/data/fixtures
FIXTURES_DIR=

# Directory where backtest task JSON state files are persisted.
# Default: <repo>/backend/data/backtest_tasks
BACKTEST_TASK_DIR=

# Active market data source. One of: fixture, akshare.
# - fixture (default): reads from backend/data/fixtures/*.csv
# - akshare: real-time data via akshare library (requires `pip install -r requirements-realtime.txt`)
#   All akshare calls hit a SQLite cache table `market_bar_cache` first.
ETF_DATA_SOURCE=fixture
